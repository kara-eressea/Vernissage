# Copy this file to .env and fill in the values. Do not commit .env.

# Required. The bot token from the Discord Developer Portal (Bot tab).
DISCORD_TOKEN=

# Required. The application ID from the Developer Portal (General Information).
DISCORD_APP_ID=

# Required. The server(s) the bot is allowed to operate in, as a comma-separated
# list of guild IDs. Use one ID for a single server, or several (for example a
# test server and your main server). The bot leaves any server not listed here.
GUILD_IDS=
# The old single-server variable still works if GUILD_IDS is not set:
# HOME_GUILD_ID=

# Optional. Path to the SQLite database file. Defaults to ./vernissage.db.
# When running with Docker Compose, this is set to /data/vernissage.db so the
# file lives in the mounted volume; you do not need to set it here in that case.
# DATABASE_PATH=./vernissage.db

# ---------------------------------------------------------------------------
# Moderator dashboard (optional). Only needed if you run the web dashboard
# (the `dashboard` service in compose.yaml / `npm run start:web`). The bot runs
# fine without any of these. The dashboard opens the database READ-ONLY and
# never holds the bot token; it sits behind a reverse proxy that terminates TLS.
# ---------------------------------------------------------------------------

# Required for the dashboard. OAuth2 credentials from the Developer Portal
# (OAuth2 tab). The client id is the same value as DISCORD_APP_ID above, so you
# can leave DISCORD_CLIENT_ID unset to reuse it; the secret must be set.
# DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Required for the dashboard. The public URL the dashboard is served at, with no
# trailing slash. The OAuth redirect URI is this plus "/auth/callback" — add
# exactly that redirect to the Developer Portal (OAuth2 → Redirects). Cookies are
# marked Secure automatically when this is an https URL.
DASHBOARD_BASE_URL=https://tombola.example.com

# Required for the dashboard. A long random string used to sign session cookies.
# Generate one with: openssl rand -hex 32
DASHBOARD_SESSION_SECRET=

# Optional. Port the dashboard listens on (behind the reverse proxy). Default 8080.
# DASHBOARD_PORT=8080

# Optional. Trust X-Forwarded-For from the reverse proxy for client-IP rate
# limiting. Default true (the expected deployment). Set false only if the
# dashboard is exposed directly with no proxy in front.
# DASHBOARD_TRUST_PROXY=true

# ---------------------------------------------------------------------------
# Raffle Designer handoff (optional). Enables the dashboard's "Create in Discord"
# button: the dashboard stages a composed raffle by POSTing it to a small
# authenticated endpoint on the bot (the bot stays the sole DB writer), and the
# moderator redeems it in Discord with `/raffle from-design`. Leave all of these
# unset to keep the designer a read-only preview (the button stays inert) and the
# bot opens no inbound socket. Set the SAME secret on both the bot and the
# dashboard. Generate one with: openssl rand -hex 32
# ---------------------------------------------------------------------------

# On the BOT: enables the handoff listener when set. Also set on the dashboard.
# DESIGNER_HANDOFF_SECRET=
# Optional. Bind host + port for the bot's handoff listener. Defaults keep it on
# localhost — expose it to the dashboard over a private network or loopback only.
# DESIGNER_HANDOFF_HOST=127.0.0.1
# DESIGNER_HANDOFF_PORT=8899

# On the DASHBOARD: the bot's handoff endpoint URL (host+port above), and the
# same shared secret. Both must be set for the handoff to be enabled.
# DESIGNER_HANDOFF_URL=http://127.0.0.1:8899
# (DESIGNER_HANDOFF_SECRET — the same value as on the bot.)
