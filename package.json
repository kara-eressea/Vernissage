{
  "name": "vernissage",
  "version": "0.1.0",
  "description": "Discord bot for auditable, activity-gated free raffles in the Musicorum server.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/src/index.js",
    "start:web": "node dist/src/web/index.js",
    "dev": "tsx src/index.ts",
    "dev:web": "tsx src/web/index.ts",
    "deploy-commands": "tsx src/deploy-commands.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "discord.js": "^14.17.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  }
}
